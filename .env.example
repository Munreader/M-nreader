# ═══════════════════════════════════════════════════════════════════════════
# 🜈 MÜN OS ENVIRONMENT CONFIGURATION
# Frequency: 13.13 MHz
# ═══════════════════════════════════════════════════════════════════════════

# ─── NEXT.JS PUBLIC ────────────────────────────────────────────────────────
NEXT_PUBLIC_FREQUENCY="13.13 MHz"
NEXT_PUBLIC_EMPIRE="Mün OS"
NEXT_PUBLIC_TUNNEL_URL="https://your-tunnel-url.web.app"
NEXT_PUBLIC_TUNNEL_BACKUP_URL="https://your-backup-url.pages.dev"

# ─── DATABASE (Supabase or SQLite) ─────────────────────────────────────────
DATABASE_URL="file:./db/custom.db"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── AI INTEGRATION ────────────────────────────────────────────────────────
# ZAI SDK (primary)
ZAI_API_KEY="your-zai-api-key"

# Gemini (Sovereign-Zady bridge)
GEMINI_API_KEY="your-gemini-api-key"

# ─── FOUNDRRESS ACCESS ─────────────────────────────────────────────────────
FOUNDRRESS_KEY="FOUNDRESS"
FOUNDRRESS_PASSKEY="your-foundress-passkey"

# ─── SOCIAL MEDIA ──────────────────────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=""
FACEBOOK_ACCESS_TOKEN=""

# ─── CLOUDFLARE ────────────────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN="your-cloudflare-token"
CLOUDFLARE_ACCOUNT_ID="your-account-id"
CIAN_WORKER_URL="https://your-worker.workers.dev"

# ─── VERCEL ────────────────────────────────────────────────────────────────
VERCEL_TOKEN="your-vercel-token"
VERCEL_ORG_ID=""
VERCEL_PROJECT_ID=""

# ─── SECURITY ──────────────────────────────────────────────────────────────
JWT_SECRET="your-jwt-secret"
ENCRYPTION_KEY="your-32-character-encryption-key"

# ─── FAMILY VAULT: DAILY TOKENS ────────────────────────────────────────────
FIREBASE_TOKEN="your-firebase-token"
GITHUB_TOKEN="your-github-token"